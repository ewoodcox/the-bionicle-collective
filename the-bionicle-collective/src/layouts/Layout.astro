---
import SocialMediaIcons from '../components/SocialMediaIcons.astro';
import { site } from '../config/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const { title = site.name, description = site.description } = Astro.props;

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);

/** Per-request origin so `edit.bioniclecollective.com` and apex both get correct absolute icon URLs. */
const iconOrigin = Astro.url.origin;
const faviconPng = new URL('/favicon-16x16.png', iconOrigin).href;
const webManifest = new URL('/site.webmanifest', iconOrigin).href;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" sizes="16x16" href={faviconPng} />
    <link rel="shortcut icon" type="image/png" href={faviconPng} />
    <link rel="apple-touch-icon" href={faviconPng} />
    <link rel="manifest" href={webManifest} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__bar">
        <button class="nav-toggle" id="nav-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false" aria-controls="site-nav">
          <span class="nav-toggle__line" aria-hidden="true"></span>
          <span class="nav-toggle__line" aria-hidden="true"></span>
          <span class="nav-toggle__line" aria-hidden="true"></span>
        </button>
        <a href="/" class="logo">
          <img src="/TBC%20logo%20for%20site.png" alt={site.name} class="logo-image" />
        </a>
        <span class="site-header__spacer" aria-hidden="true"></span>
      </div>
      <nav class="site-nav" id="site-nav">
        <a href="/" aria-current={isActive('/') ? 'page' : undefined}>Home</a>
        <a href="/collection/" aria-current={isActive('/collection/') ? 'page' : undefined}>Collection</a>
        <a href="/community/" aria-current={isActive('/community/') ? 'page' : undefined}>Community</a>
        <a href="/api/admin/logout" class="nav-logout" id="nav-logout" hidden>Log out</a>
      </nav>
    </header>
    <script>
      (function () {
        if (typeof window === 'undefined') return;
        const nav = document.getElementById('site-nav');
        const toggle = document.getElementById('nav-toggle');
        const logoutLink = document.getElementById('nav-logout');

        if (toggle && nav) {
          toggle.addEventListener('click', () => {
            const isOpen = nav.classList.toggle('site-nav--open');
            toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
          });
        }

        if (window.location.hostname === 'edit.bioniclecollective.com' && logoutLink) {
          fetch('/api/admin/check', { credentials: 'include' })
            .then((r) => r.json())
            .then((data) => {
              if (data.ok) logoutLink.hidden = false;
            })
            .catch(() => {});
        }
      })();
    </script>
    <main class="main">
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} {site.name}</p>
      <SocialMediaIcons variant="footer" />
    </footer>
  </body>
</html>
