---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---
<Layout title="404 – Page Not Found | The Bionicle Collective" description="This page could not be found.">
  <div class="not-found">
    <div class="not-found__code">404</div>
    <h1 class="not-found__heading">Page Not Found</h1>
    <p class="not-found__body">The set you're looking for has escaped the archives.</p>
    <div class="not-found__actions">
      <a href="/" class="button-primary">← Home</a>
      <a href="/collection/" class="button-primary">View collection</a>
    </div>
  </div>
</Layout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 10rem);
    text-align: center;
    gap: 1rem;
  }

  .not-found__code {
    font-family: var(--font-heading);
    font-size: clamp(6rem, 20vw, 12rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-accent);
    text-shadow: 0 0 60px var(--glow-accent), 0 0 120px rgba(196, 137, 60, 0.2);
    user-select: none;
  }

  .not-found__heading {
    font-size: clamp(1.25rem, 4vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--color-text);
  }

  .not-found__body {
    color: var(--color-text-muted);
    font-size: 1rem;
    margin: 0;
  }

  .not-found__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }
</style>
