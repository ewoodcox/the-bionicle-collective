---
import Layout from '../layouts/Layout.astro';
import SocialMediaIcons from '../components/SocialMediaIcons.astro';
import { site } from '../config/site';
import { sets } from '../data/sets';
import { getKanohiOwnedIds } from '../utils/kanohiStoreR2';
import kanohiCollectionStatic from '../data/kanohi-collection.json';
import { getKranaOwnedIds } from '../utils/kranaStoreR2';
import kranaCollectionStatic from '../data/krana-collection.json';
import { getKrana } from '../data/krana';
import { getKanokaOwnedIds } from '../utils/kanokaStoreR2';
import kanokaCollectionStatic from '../data/kanoka-collection.json';
import { getKanoka } from '../data/kanoka';
import { isAuthenticated } from '../utils/adminAuth';
import { getUniqueItems } from '../utils/uniqueStoreR2';

const EDIT_HOST = 'edit.bioniclecollective.com';
const isEditHost = (Astro.request.headers.get('Host') ?? '') === EDIT_HOST;
const env = (Astro.locals as any).runtime?.env;
const isAuthed = isEditHost ? await isAuthenticated(Astro.request, env) : true;
const hasGoogleAuth = isEditHost && !!env?.GOOGLE_CLIENT_ID;

// Only load home page data when we're going to show it
const years = [...new Set(sets.map(s => s.year))].sort((a, b) => a - b);
const yearRange = `${years[0]}–${years[years.length - 1]}`;

const bucket = env?.BIONICLE_COLLECTION;
let ownedKanohiCount: number;
try {
  const ids = bucket ? await getKanohiOwnedIds(bucket) : (kanohiCollectionStatic as string[]);
  ownedKanohiCount = ids.length;
} catch {
  ownedKanohiCount = (kanohiCollectionStatic as string[]).length;
}

let uniqueItemCount = 0;
try {
  if (bucket) {
    const items = await getUniqueItems(bucket);
    uniqueItemCount = items.length;
  }
} catch {
  uniqueItemCount = 0;
}

let ownedKranaCount: number;
try {
  const kranaIds = bucket ? await getKranaOwnedIds(bucket) : (kranaCollectionStatic as string[]);
  ownedKranaCount = kranaIds.length;
} catch {
  ownedKranaCount = (kranaCollectionStatic as string[]).length;
}
const totalKranaCount = getKrana().length;

let ownedKanokaCount: number;
try {
  const kanokaIds = bucket ? await getKanokaOwnedIds(bucket) : (kanokaCollectionStatic as string[]);
  ownedKanokaCount = kanokaIds.length;
} catch {
  ownedKanokaCount = (kanokaCollectionStatic as string[]).length;
}
const totalKanokaCount = getKanoka().length;

const totalSetCount = sets.length + uniqueItemCount;

// Preserve ?next= so login can redirect back to the intended page
const nextParam = Astro.url.searchParams.get('next') ?? '/collection/';
const next = nextParam.startsWith('/') ? nextParam : '/collection/';
---
<Layout title={site.name} description={site.description}>
  {isEditHost && !isAuthed ? (
    <!-- Login gate: server-rendered, no JS flash -->
    <div class="edit-gate">
      <div class="edit-gate-inner">
        <h1 class="site-title">{site.name}</h1>
        <p class="edit-gate-subtitle">Sign in to unlock editing</p>
        <p class="edit-gate-status" id="edit-gate-status" aria-live="polite"></p>
        <form id="edit-gate-form" class="edit-gate-form">
          <input type="text" id="edit-gate-username" class="edit-gate-input" name="username" placeholder="Username" autocomplete="username" required />
          <input type="password" id="edit-gate-password" class="edit-gate-input" name="password" placeholder="Password" autocomplete="current-password" required />
          <button type="submit" class="button-primary">Sign in</button>
        </form>
        {hasGoogleAuth && (
          <>
            <div class="edit-gate-divider"><span>or</span></div>
            <a href={`/api/admin/auth/google?next=${encodeURIComponent(next)}`} class="google-signin-btn">
              <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
                <path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z"/>
                <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.258c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z"/>
                <path fill="#FBBC05" d="M3.964 10.707A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.707V4.961H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.039l3.007-2.332z"/>
                <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.961L3.964 7.293C4.672 5.163 6.656 3.58 9 3.58z"/>
              </svg>
              Sign in with Google
            </a>
          </>
        )}
      </div>
    </div>
  ) : (
    <div class="home-page">
      <div class="home-hero">
        <h1 class="site-title">{site.name}</h1>
        <SocialMediaIcons variant="home" />
        <hr class="home-about-divider" />
        <p class="home-description">{site.description}</p>
        <p class="home-cta">
          <a href="/collection/" class="button-primary">View the collection</a>
        </p>
        <div class="hero-stats">
          <a href="/stats/sets/" class="hero-stat hero-stat--link">
            <span class="hero-stat__value">{totalSetCount}</span>
            <span class="hero-stat__label">Sets</span>
          </a>
          <div class="hero-stat__sep"></div>
          <div class="hero-stat">
            <span class="hero-stat__value">{yearRange}</span>
            <span class="hero-stat__label">Years</span>
          </div>
          <div class="hero-stat__sep"></div>
          <a href="/kanohi/" class="hero-stat hero-stat--link">
            <span class="hero-stat__value">{ownedKanohiCount}</span>
            <span class="hero-stat__label">Kanohi</span>
          </a>
          {totalKranaCount > 0 && (
            <>
              <div class="hero-stat__sep"></div>
              <a href="/krana/" class="hero-stat hero-stat--link">
                <span class="hero-stat__value">{ownedKranaCount}</span>
                <span class="hero-stat__label">Krana</span>
              </a>
            </>
          )}
          {totalKanokaCount > 0 && (
            <>
              <div class="hero-stat__sep"></div>
              <a href="/kanoka/" class="hero-stat hero-stat--link">
                <span class="hero-stat__value">{ownedKanokaCount}</span>
                <span class="hero-stat__label">Kanoka</span>
              </a>
            </>
          )}
        </div>
      </div>
    </div>
  )}
</Layout>

{isEditHost && !isAuthed && (
  <script define:vars={{ next }}>
    const statusEl = document.getElementById('edit-gate-status');
    const formEl = document.getElementById('edit-gate-form');

    formEl.addEventListener('submit', (e) => {
      e.preventDefault();
      const username = document.getElementById('edit-gate-username').value.trim();
      const password = document.getElementById('edit-gate-password').value;
      if (!username || !password) return;
      statusEl.textContent = '';

      fetch(`/api/admin/login?next=${encodeURIComponent(next)}`, {
        method: 'POST',
        body: JSON.stringify({ username, password }),
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
      }).then((res) => {
        if (res.ok) {
          window.location.href = next;
          return;
        }
        res.json()
          .then((data) => {
            statusEl.textContent = data.error || 'Invalid credentials';
          })
          .catch(() => {
            statusEl.textContent = res.status === 503
              ? 'Admin login not configured. Set ADMIN_SECRET in Cloudflare Pages env.'
              : `Login failed (${res.status}).`;
          });
      }).catch(() => {
        statusEl.textContent = 'Network error. Please try again.';
      });
    });
  </script>
)}
