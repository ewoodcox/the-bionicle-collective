---
import Layout from '../layouts/Layout.astro';
import SocialMediaIcons from '../components/SocialMediaIcons.astro';
import { site } from '../config/site';
import { sets } from '../data/sets';
import { getKanohiOwnedIds } from '../utils/kanohiStoreR2';
import kanohiCollectionStatic from '../data/kanohi-collection.json';
import { isAuthenticated } from '../utils/adminAuth';
import { getUniqueItems } from '../utils/uniqueStoreR2';

const EDIT_HOST = 'edit.bioniclecollective.com';
const isEditHost = (Astro.request.headers.get('Host') ?? '') === EDIT_HOST;
const env = (Astro.locals as any).runtime?.env;
const isAuthed = isEditHost ? await isAuthenticated(Astro.request, env) : true;

// Only load home page data when we're going to show it
const years = [...new Set(sets.map(s => s.year))].sort((a, b) => a - b);
const yearRange = `${years[0]}–${years[years.length - 1]}`;

const bucket = env?.BIONICLE_COLLECTION;
let ownedKanohiCount: number;
try {
  const ids = bucket ? await getKanohiOwnedIds(bucket) : (kanohiCollectionStatic as string[]);
  ownedKanohiCount = ids.length;
} catch {
  ownedKanohiCount = (kanohiCollectionStatic as string[]).length;
}

let uniqueItemCount = 0;
try {
  if (bucket) {
    const items = await getUniqueItems(bucket);
    uniqueItemCount = items.length;
  }
} catch {
  uniqueItemCount = 0;
}

const totalSetCount = sets.length + uniqueItemCount;

// Preserve ?next= so login can redirect back to the intended page
const nextParam = Astro.url.searchParams.get('next') ?? '/collection/';
const next = nextParam.startsWith('/') ? nextParam : '/collection/';
---
<Layout title={site.name} description={site.description}>
  {isEditHost && !isAuthed ? (
    <!-- Login gate: server-rendered, no JS flash -->
    <div class="edit-gate">
      <div class="edit-gate-inner">
        <h1 class="site-title">{site.name}</h1>
        <p class="edit-gate-subtitle">Enter your key to unlock editing</p>
        <p class="edit-gate-status" id="edit-gate-status" aria-live="polite"></p>
        <form id="edit-gate-form" class="edit-gate-form">
          <input type="password" id="edit-gate-key" class="edit-gate-input" name="key" placeholder="Edit key" autocomplete="off" required />
          <button type="submit" class="button-primary">Unlock editing</button>
        </form>
      </div>
    </div>
  ) : (
    <div class="home-page">
      <div class="home-hero">
        <h1 class="site-title">{site.name}</h1>
        <SocialMediaIcons variant="home" />
        <hr class="home-about-divider" />
        <p class="home-description">{site.description}</p>
        <p class="home-cta">
          <a href="/collection/" class="button-primary">View the collection</a>
        </p>
        <div class="hero-stats">
          <a href="/stats/sets/" class="hero-stat hero-stat--link">
            <span class="hero-stat__value">{totalSetCount}</span>
            <span class="hero-stat__label">Sets</span>
          </a>
          <div class="hero-stat__sep"></div>
          <div class="hero-stat">
            <span class="hero-stat__value">{yearRange}</span>
            <span class="hero-stat__label">Years</span>
          </div>
          <div class="hero-stat__sep"></div>
          <a href="/kanohi/" class="hero-stat hero-stat--link">
            <span class="hero-stat__value">{ownedKanohiCount}</span>
            <span class="hero-stat__label">Kanohi</span>
          </a>
        </div>
      </div>
    </div>
  )}
</Layout>

{isEditHost && !isAuthed && (
  <script define:vars={{ next }}>
    const statusEl = document.getElementById('edit-gate-status');
    const formEl = document.getElementById('edit-gate-form');

    formEl.addEventListener('submit', (e) => {
      e.preventDefault();
      const key = document.getElementById('edit-gate-key').value.trim();
      if (!key) return;
      statusEl.textContent = '';

      fetch(`/api/admin/login?next=${encodeURIComponent(next)}`, {
        method: 'POST',
        body: JSON.stringify({ key }),
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
      }).then((res) => {
        if (res.ok) {
          window.location.href = next;
          return;
        }
        res.json()
          .then((data) => {
            statusEl.textContent = data.error || 'Invalid key';
          })
          .catch(async () => {
            statusEl.textContent = res.status === 503
              ? 'Admin login not configured. Set ADMIN_SECRET in Cloudflare Pages env.'
              : `Login failed (${res.status}).`;
          });
      }).catch(() => {
        statusEl.textContent = 'Network error. Please try again.';
      });
    });
  </script>
)}
