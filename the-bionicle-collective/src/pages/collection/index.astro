---
import Layout from '../../layouts/Layout.astro';
import SetCarouselStrip from '../../components/SetCarouselStrip.astro';
import { sets } from '../../data/sets';
import { getSetDisplayLabel, getSetNumber, getSetSortKey, getMissingSetEntries } from '../../data/setNamesByYear';
import { YEAR_GROUPS, getYearGroup, getYearsForGroup } from '../../config/constants';
import { getMasksByYear, getKanohiYears } from '../../data/kanohi';
import { MEDIA_CATEGORIES, mediaItems, getMediaCardName, getMediaCoverSrc, type MediaCategoryId } from '../../data/media';
import { getMediaEraLabel, sortMediaByEra } from '../../data/mediaEras';
import type { SetRecord } from '../../data/sets';

const byGroup = new Map<string, SetRecord[]>();
for (const g of YEAR_GROUPS) byGroup.set(g.id, []);
for (const s of sets) {
  const year = Number(s.year);
  const group = getYearGroup(year);
  byGroup.get(group)!.push(s);
}
for (const [, list] of byGroup) list.sort((a, b) => getSetSortKey(a) - getSetSortKey(b));

// Show tabs for Gen 1, Gen 2, Other and a separate Media tab.
const EXTRA_GROUPS: readonly { id: string; label: string; labelShort?: string }[] = [{ id: 'other', label: 'Other' }, { id: 'media', label: 'Media' }];
const VISIBLE_GROUPS = [...YEAR_GROUPS.filter((g) => g.id === 'gen1' || g.id === 'gen2'), ...EXTRA_GROUPS];
const kanohiYears = getKanohiYears();
const hasKanohi = kanohiYears.length > 0;
const groupsWithData = VISIBLE_GROUPS.filter((g) => {
  if (g.id === 'other')
    return (
      sets.some((s) => {
        const theme = s.theme ?? '';
        return theme === 'Combiner Models' || theme === 'Alternate Models';
      }) || hasKanohi
    );
  if (g.id === 'media') return mediaItems.length > 0;
  return (byGroup.get(g.id) ?? []).length > 0;
});
const defaultGroupId =
  groupsWithData.find((g) => g.id === 'gen1')?.id ??
  groupsWithData[0]?.id ??
  VISIBLE_GROUPS[0]?.id ??
  null;
---
<Layout title="Meet the Collective | The Bionicle Collective" description="Bionicle collection by year.">
  <div class="collection-page">
  <h1>Meet the Collective</h1>
  <p style="text-align: center; margin-top: 0.25rem; margin-bottom: 1.5rem;">
    Here you can browse through the individual sets and other items that make up The Bionicle Collective.
  </p>

  {VISIBLE_GROUPS.length > 1 && (
    <div class="generation-tabs" role="tablist" aria-label="Select generation">
      {VISIBLE_GROUPS.map((group) => (
        <button
          type="button"
          class="generation-tab"
          role="tab"
          aria-selected={group.id === defaultGroupId}
          data-group-id={group.id}
        >
          {group.labelShort ? (
            <>
              <span class="generation-tab-full">{group.label}</span>
              <span class="generation-tab-short">{group.labelShort}</span>
            </>
          ) : (
            group.label
          )}
        </button>
      ))}
    </div>
  )}

  <div class="bulk-edit-toggle-row" data-edit-only>
    <button type="button" class="bulk-edit-toggle-btn" id="bulk-edit-toggle">Bulk edit</button>
  </div>

  {VISIBLE_GROUPS.map((group) => {
    const items =
      group.id === 'other'
        ? sets.filter((s) => {
            const theme = s.theme ?? '';
            return theme === 'Combiner Models' || theme === 'Alternate Models';
          })
        : group.id === 'media'
        ? mediaItems
        : (byGroup.get(group.id) ?? []).filter((s) => {
            const theme = s.theme ?? '';
            return theme !== 'Combiner Models' && theme !== 'Alternate Models';
          });

    const years = getYearsForGroup(group.id);
    const hasCarousel = years.length > 0;
    const yearsWithData = hasCarousel
      ? years.filter((y) => items.some((s) => Number(s.year) === y))
      : [];
    const firstYear = yearsWithData.length > 0 ? yearsWithData[0] : null;

    // Media tab split:
    // - Comics/Books: single continuous carousel ordered by story eras (no year/category panes).
    // - Disks/Games/Cards: keep the existing year + category tab UI.
    const isMedia = group.id === 'media';
    const mediaComicsItems = isMedia ? items.filter((m) => m.category === 'comics') : [];
    const mediaBooksItems = isMedia ? items.filter((m) => m.category === 'books') : [];
    const mediaOtherItems = isMedia ? items.filter((m) => m.category !== 'comics' && m.category !== 'books') : [];
    const mediaOtherCategories = isMedia ? MEDIA_CATEGORIES.filter((c) => c.id !== 'comics' && c.id !== 'books') : [];
    const otherYearsWithData = isMedia ? years.filter((y) => mediaOtherItems.some((s) => Number(s.year) === y)) : [];
    const otherFirstYear = otherYearsWithData.length > 0 ? otherYearsWithData[0] : null;
    const otherFirstCategoryId = mediaOtherCategories[0]?.id ?? '';

    const hasCombiner = group.id === 'other' && items.some((s) => (s.theme ?? '') === 'Combiner Models');
    const hasAlternate = group.id === 'other' && items.some((s) => (s.theme ?? '') === 'Alternate Models');
    const hasPromotional = group.id === 'other' && items.some((s) => (s.theme ?? '') === 'Promotional');
    const firstOtherTab =
      group.id === 'other' ? (hasCombiner ? 'combiner' : hasAlternate ? 'alternate' : hasPromotional ? 'promotional' : 'kanohi') : '';

    return (
      <section class="collection-section" id={group.id} data-group-id={group.id} data-active={group.id === defaultGroupId}>
        {items.length === 0 && !(group.id === 'other' && hasKanohi) ? (
          <p class="collection-empty">No sets added yet for this generation.</p>
        ) : group.id === 'other' ? (
          <>
            <div
              class="year-carousel"
              role="tablist"
              aria-label={`Select group for ${group.label}`}
              data-group-id={group.id}
            >
              {hasCombiner && (
                <button
                  type="button"
                  role="tab"
                  aria-selected={firstOtherTab === 'combiner'}
                  aria-controls={`${group.id}-year-combiner`}
                  id={`${group.id}-tab-combiner`}
                  data-year="combiner"
                  data-group-id={group.id}
                >
                  Combiner Models
                </button>
              )}
              {hasAlternate && (
                <button
                  type="button"
                  role="tab"
                  aria-selected={firstOtherTab === 'alternate'}
                  aria-controls={`${group.id}-year-alternate`}
                  id={`${group.id}-tab-alternate`}
                  data-year="alternate"
                  data-group-id={group.id}
                >
                  Alternate Models
                </button>
              )}
              {hasPromotional && (
                <button
                  type="button"
                  role="tab"
                  aria-selected={firstOtherTab === 'promotional'}
                  aria-controls={`${group.id}-year-promotional`}
                  id={`${group.id}-tab-promotional`}
                  data-year="promotional"
                  data-group-id={group.id}
                >
                  Promotional
                </button>
              )}
              {hasKanohi && (
                <button
                  type="button"
                  role="tab"
                  aria-selected={firstOtherTab === 'kanohi'}
                  aria-controls={`${group.id}-year-kanohi`}
                  id={`${group.id}-tab-kanohi`}
                  data-year="kanohi"
                  data-group-id={group.id}
                >
                  Kanohi
                </button>
              )}
            </div>
            {hasCombiner && (
              <div
                class="year-pane"
                id={`${group.id}-year-combiner`}
                role="tabpanel"
                aria-labelledby={`${group.id}-tab-combiner`}
                data-year="combiner"
                data-group-id={group.id}
                data-active={firstOtherTab === 'combiner'}
              >
                <SetCarouselStrip
                  ariaLabel="Combiner models"
                  carouselKind="other-combiner"
                  prevLabel="Scroll combiner models left"
                  nextLabel="Scroll combiner models right"
                >
                  {items
                    .filter((s) => (s.theme ?? '') === 'Combiner Models')
                    .map((set) => (
                      <a href={`/collection/${set.id}/?gen=${group.id}&year=combiner`} class="set-card media-era-card" data-set-id={set.id}>
                        <img src={`/api/sets/photo/${set.id}`} alt={getSetDisplayLabel(set)} width="160" height="160" loading="lazy" />
                        <div class="info">
                          <div class="name">{getSetDisplayLabel(set)}</div>
                          <div class="meta">{set.year}</div>
                        </div>
                        <span class="bulk-select-box" aria-hidden="true"></span>
                      </a>
                    ))}
                </SetCarouselStrip>
              </div>
            )}
            {hasAlternate && (
              <div
                class="year-pane"
                id={`${group.id}-year-alternate`}
                role="tabpanel"
                aria-labelledby={`${group.id}-tab-alternate`}
                data-year="alternate"
                data-group-id={group.id}
                data-active={firstOtherTab === 'alternate'}
              >
                <SetCarouselStrip
                  ariaLabel="Alternate models"
                  carouselKind="other-alternate"
                  prevLabel="Scroll alternate models left"
                  nextLabel="Scroll alternate models right"
                >
                  {items
                    .filter((s) => (s.theme ?? '') === 'Alternate Models')
                    .map((set) => (
                      <a href={`/collection/${set.id}/?gen=${group.id}&year=alternate`} class="set-card media-era-card" data-set-id={set.id}>
                        <img src={`/api/sets/photo/${set.id}`} alt={getSetDisplayLabel(set)} width="160" height="160" loading="lazy" />
                        <div class="info">
                          <div class="name">{getSetDisplayLabel(set)}</div>
                          <div class="meta">{set.year}</div>
                        </div>
                        <span class="bulk-select-box" aria-hidden="true"></span>
                      </a>
                    ))}
                </SetCarouselStrip>
              </div>
            )}
            {hasPromotional && (
              <div
                class="year-pane"
                id={`${group.id}-year-promotional`}
                role="tabpanel"
                aria-labelledby={`${group.id}-tab-promotional`}
                data-year="promotional"
                data-group-id={group.id}
                data-active={firstOtherTab === 'promotional'}
              >
                <SetCarouselStrip
                  ariaLabel="Promotional sets"
                  carouselKind="other-promotional"
                  prevLabel="Scroll promotional sets left"
                  nextLabel="Scroll promotional sets right"
                >
                  {items
                    .filter((s) => (s.theme ?? '') === 'Promotional')
                    .sort((a, b) => a.year - b.year)
                    .map((set) => (
                      <a href={`/collection/${set.id}/?gen=${group.id}&year=promotional`} class="set-card media-era-card" data-set-id={set.id}>
                        <img src={`/api/sets/photo/${set.id}`} alt={getSetDisplayLabel(set)} width="160" height="160" loading="lazy" />
                        <div class="info">
                          <div class="name">{getSetDisplayLabel(set)}</div>
                          <div class="meta">{set.year}</div>
                        </div>
                        <span class="bulk-select-box" aria-hidden="true"></span>
                      </a>
                    ))}
                </SetCarouselStrip>
              </div>
            )}
            {hasKanohi && (
              <div
                class="year-pane"
                id={`${group.id}-year-kanohi`}
                role="tabpanel"
                aria-labelledby={`${group.id}-tab-kanohi`}
                data-year="kanohi"
                data-group-id={group.id}
                data-active={firstOtherTab === 'kanohi'}
              >
                <div
                  class="year-carousel"
                  role="tablist"
                  aria-label="Select year for Kanohi"
                  data-group-id="other-kanohi"
                >
                  {kanohiYears.map((y) => (
                    <button
                      type="button"
                      role="tab"
                      aria-selected={y === kanohiYears[0]}
                      aria-controls={`other-kanohi-year-${y}`}
                      id={`other-kanohi-tab-${y}`}
                      data-year={String(y)}
                      data-group-id="other-kanohi"
                    >
                      {y}
                    </button>
                  ))}
                </div>
                {kanohiYears.map((y) => {
                  const yearMasks = getMasksByYear(y);
                  return (
                    <div
                      class="year-pane"
                      id={`other-kanohi-year-${y}`}
                      role="tabpanel"
                      aria-labelledby={`other-kanohi-tab-${y}`}
                      data-year={String(y)}
                      data-group-id="other-kanohi"
                      data-active={y === kanohiYears[0]}
                    >
                      <SetCarouselStrip
                        ariaLabel={`Kanohi for ${y}`}
                        carouselKind={`other-kanohi-${y}`}
                        prevLabel={`Scroll Kanohi for ${y} left`}
                        nextLabel={`Scroll Kanohi for ${y} right`}
                      >
                        {yearMasks.map((mask) => (
                          <div
                            class={`set-card mask-card media-era-card${mask.owned ? '' : ' set-card--missing'}`}
                            data-mask-id={mask.id}
                            aria-label={`${mask.name} ${mask.colorLabel}${mask.owned ? ', owned' : ', not owned'}`}
                          >
                            <img
                              src={mask.imageUrl}
                              data-fallback={`https://img.bricklink.com/ItemImage/PN/${mask.bricklinkColorId}/${mask.partId}.png`}
                              alt={`${mask.name} - ${mask.colorLabel}`}
                              width="160"
                              height="160"
                              loading="lazy"
                              onerror="this.onerror=null;this.src=this.dataset.fallback"
                            />
                            <div class="info">
                              <div class="name">{mask.name} - {mask.colorLabel}</div>
                              <div class="meta">{mask.year} · {mask.type}</div>
                            </div>
                            <label class="mask-card-checkbox-wrap" aria-label={`${mask.name} - mark as owned`} data-edit-only>
                              <input type="checkbox" class="mask-card-checkbox" data-mask-id={mask.id} checked={mask.owned} />
                              <span class="mask-card-checkbox-box" aria-hidden="true"></span>
                            </label>
                          </div>
                        ))}
                      </SetCarouselStrip>
                    </div>
                  );
                })}
                <div class="kanohi-save-row" data-edit-only>
                  <button type="button" class="kanohi-save-btn">Save Kanohi ownership</button>
                </div>
              </div>
            )}
          </>
        ) : hasCarousel && yearsWithData.length > 0 ? (
          <>
            {group.id !== 'media' && (
              <div
                class="year-carousel"
                role="tablist"
                aria-label={`Select year for ${group.label}`}
                data-group-id={group.id}
              >
                {yearsWithData.map((y) => (
                  <button
                    type="button"
                    role="tab"
                    aria-selected={y === firstYear}
                    aria-controls={`${group.id}-year-${y}`}
                    id={`${group.id}-tab-${y}`}
                    data-year={String(y)}
                    data-group-id={group.id}
                  >
                    {y}
                  </button>
                ))}
              </div>
            )}

            {group.id === 'media' ? (
              <>
                {mediaComicsItems.length > 0 && (
                  <div class="media-era-carousel-section">
                    <div class="media-era-carousel-wrap" data-carousel-kind="comics">
                      <div class="media-era-carousel-header">
                        <div class="media-era-carousel-title">Comics by Era</div>
                      </div>

                      <div class="media-era-carousel-controls" aria-hidden="false">
                        <button type="button" class="media-era-prev" aria-label="Scroll comics left">
                          ←
                        </button>
                        <button type="button" class="media-era-next" aria-label="Scroll comics right">
                          →
                        </button>
                      </div>

                      <div class="media-era-carousel" role="region" aria-label="Comics carousel">
                        {sortMediaByEra(mediaComicsItems).map((m) => {
                          const eraLabel = getMediaEraLabel(m);
                          const catLabel = 'Comics';
                          return (
                            <div
                              class="set-card media-card media-era-card"
                              role="link"
                              tabindex="0"
                              data-media-id={m.id}
                              data-media-href={`/media/${m.id}/`}
                              aria-label={`${getMediaCardName(m)}, ${eraLabel} ${catLabel}`}
                            >
                              <div class="media-cover-stack" aria-hidden="true">
                                <img
                                  class="media-cover-main"
                                  src={getMediaCoverSrc(m, 'main')}
                                  alt={m.title}
                                  width="160"
                                  height="240"
                                  loading="lazy"
                                />
                                {m.imageUrlAlt ? (
                                  <img
                                    class="media-cover-alt"
                                    src={getMediaCoverSrc(m, 'alt')}
                                    alt=""
                                    width="160"
                                    height="240"
                                    loading="lazy"
                                    aria-hidden="true"
                                  />
                                ) : null}
                              </div>
                              <div class="info">
                                <div class="name">{getMediaCardName(m)}</div>
                                <div class="meta">
                                  {eraLabel} · {catLabel}
                                </div>
                              </div>

                              <button
                                class="media-card-view-btn"
                                data-edit-only
                                aria-label={`View ${getMediaCardName(m)}`}
                                onClick="event.stopPropagation();"
                              >↗</button>
                              <label
                                class="media-card-checkbox-wrap"
                                aria-label={`${getMediaCardName(m)} - mark as owned`}
                                data-edit-only
                                onClick="event.stopPropagation();"
                              >
                                <input
                                  type="checkbox"
                                  class="media-card-checkbox"
                                  data-media-id={m.id}
                                  onClick="event.stopPropagation();"
                                />
                                <span class="media-card-checkbox-box" aria-hidden="true"></span>
                              </label>
                            </div>
                          );
                        })}
                      </div>
                    </div>
                  </div>
                )}

                {mediaBooksItems.length > 0 && (
                  <div class="media-era-carousel-section">
                    <div class="media-era-carousel-wrap" data-carousel-kind="books">
                      <div class="media-era-carousel-header">
                        <div class="media-era-carousel-title">Books</div>
                      </div>

                      <div class="media-era-carousel-controls" aria-hidden="false">
                        <button type="button" class="media-era-prev" aria-label="Scroll books left">
                          ←
                        </button>
                        <button type="button" class="media-era-next" aria-label="Scroll books right">
                          →
                        </button>
                      </div>

                      <div class="media-era-carousel" role="region" aria-label="Books carousel">
                        {sortMediaByEra(mediaBooksItems).map((m) => {
                          const eraLabel = getMediaEraLabel(m);
                          const catLabel = 'Books';
                          return (
                            <div
                              class="set-card media-card media-era-card"
                              role="link"
                              tabindex="0"
                              data-media-id={m.id}
                              data-media-href={`/media/${m.id}/`}
                              aria-label={`${getMediaCardName(m)}, ${eraLabel} ${catLabel}`}
                            >
                              <img
                                src={getMediaCoverSrc(m, 'main')}
                                alt={m.title}
                                width="160"
                                height="240"
                                loading="lazy"
                              />
                              <div class="info">
                                <div class="name">{getMediaCardName(m)}</div>
                                <div class="meta">
                                  {eraLabel} · {catLabel}
                                </div>
                              </div>

                              <button
                                class="media-card-view-btn"
                                data-edit-only
                                aria-label={`View ${getMediaCardName(m)}`}
                                onClick="event.stopPropagation();"
                              >↗</button>
                              <label
                                class="media-card-checkbox-wrap"
                                aria-label={`${getMediaCardName(m)} - mark as owned`}
                                data-edit-only
                                onClick="event.stopPropagation();"
                              >
                                <input
                                  type="checkbox"
                                  class="media-card-checkbox"
                                  data-media-id={m.id}
                                  onClick="event.stopPropagation();"
                                />
                                <span class="media-card-checkbox-box" aria-hidden="true"></span>
                              </label>
                            </div>
                          );
                        })}
                      </div>
                    </div>
                  </div>
                )}

                {mediaOtherItems.length > 0 && otherYearsWithData.length > 0 && (
                  <>
                    <div
                      class="year-carousel"
                      role="tablist"
                      aria-label={`Select year for ${group.label}`}
                      data-group-id={group.id}
                    >
                      {otherYearsWithData.map((y) => (
                        <button
                          type="button"
                          role="tab"
                          aria-selected={y === otherFirstYear}
                          aria-controls={`${group.id}-year-${y}`}
                          id={`${group.id}-tab-${y}`}
                          data-year={String(y)}
                          data-group-id={group.id}
                        >
                          {y}
                        </button>
                      ))}
                    </div>

                    {otherYearsWithData.map((y) => {
                      const yearKey = String(y);
                      const yearItems = mediaOtherItems.filter((m) => Number(m.year) === y);

                      return (
                        <div
                          class="year-pane"
                          id={`${group.id}-year-${yearKey}`}
                          role="tabpanel"
                          aria-labelledby={`${group.id}-tab-${y}`}
                          data-year={yearKey}
                          data-group-id={group.id}
                          data-active={y === otherFirstYear}
                        >
                          <div
                            class="media-category-tabs"
                            role="tablist"
                            aria-label={`Select media category for ${y}`}
                          >
                            {mediaOtherCategories.map((cat) => (
                              <button
                                type="button"
                                class="media-category-tab"
                                role="tab"
                                aria-selected={cat.id === otherFirstCategoryId}
                                aria-controls={`media-${yearKey}-${cat.id}`}
                                id={`media-${yearKey}-tab-${cat.id}`}
                                data-category={cat.id}
                              >
                                {cat.label}
                              </button>
                            ))}
                          </div>

                          {mediaOtherCategories.map((cat) => {
                            const catItems = yearItems.filter((m) => m.category === cat.id);
                            return (
                              <div
                                class="media-category-pane"
                                data-category={cat.id}
                                data-active={cat.id === otherFirstCategoryId}
                                role="tabpanel"
                                aria-labelledby={`media-${yearKey}-tab-${cat.id}`}
                                id={`media-${yearKey}-${cat.id}`}
                              >
                                {catItems.length === 0 ? (
                                  <p class="collection-empty">No {cat.label} entries for {y}.</p>
                                ) : (
                                  <div class="set-grid">
                                    {catItems.map((m) => {
                                      return (
                                        <div
                                          class="set-card media-card"
                                          role="link"
                                          tabindex="0"
                                          data-media-id={m.id}
                                          data-media-href={`/media/${m.id}/`}
                                          aria-label={`${getMediaCardName(m)}, ${m.year} ${cat.label}`}
                                        >
                                          <img
                                            src={getMediaCoverSrc(m, 'main')}
                                            alt={m.title}
                                            width="160"
                                            height="240"
                                            loading="lazy"
                                          />
                                          <div class="info">
                                            <div class="name">{getMediaCardName(m)}</div>
                                            <div class="meta">
                                              {m.year} · {cat.label}
                                            </div>
                                          </div>

                                          <button
                                            class="media-card-view-btn"
                                            data-edit-only
                                            aria-label={`View ${getMediaCardName(m)}`}
                                            onClick="event.stopPropagation();"
                                          >↗</button>
                                          <label
                                            class="media-card-checkbox-wrap"
                                            aria-label={`${getMediaCardName(m)} - mark as owned`}
                                            data-edit-only
                                            onClick="event.stopPropagation();"
                                          >
                                            <input
                                              type="checkbox"
                                              class="media-card-checkbox"
                                              data-media-id={m.id}
                                              onClick="event.stopPropagation();"
                                            />
                                            <span class="media-card-checkbox-box" aria-hidden="true"></span>
                                          </label>
                                        </div>
                                      );
                                    })}
                                  </div>
                                )}
                              </div>
                            );
                          })}
                        </div>
                      );
                    })}
                  </>
                )}

                <div class="media-save-row" data-edit-only>
                  <button type="button" class="media-save-btn">Save Media ownership</button>
                </div>
              </>
            ) : (
              yearsWithData.map((y) => {
                const yearKey = String(y);
                const yearItems = items.filter((s) => Number(s.year) === y);
                const ownedSetNumbers = new Set(yearItems.map((s) => getSetNumber(s)));
                const missingEntries = getMissingSetEntries(y, ownedSetNumbers);
                return (
                  <div
                    class="year-pane"
                    id={`${group.id}-year-${yearKey}`}
                    role="tabpanel"
                    aria-labelledby={`${group.id}-tab-${y}`}
                    data-year={yearKey}
                    data-group-id={group.id}
                    data-active={y === firstYear}
                  >
                    <SetCarouselStrip
                      ariaLabel={`Sets released in ${y}`}
                      carouselKind={`sets-${group.id}-${yearKey}`}
                      prevLabel={`Scroll ${y} sets left`}
                      nextLabel={`Scroll ${y} sets right`}
                    >
                      {yearItems.map((set) => (
                        <a href={`/collection/${set.id}/?gen=${group.id}&year=${y}`} class="set-card media-era-card" data-set-id={set.id}>
                          <img src={`/api/sets/photo/${set.id}`} alt={getSetDisplayLabel(set)} width="160" height="160" loading="lazy" />
                          <div class="info">
                            <div class="name">{getSetDisplayLabel(set)}</div>
                            <div class="meta">{set.year}</div>
                          </div>
                          <span class="bulk-select-box" aria-hidden="true"></span>
                        </a>
                      ))}
                    </SetCarouselStrip>
                    {missingEntries.length > 0 && (
                      <div class="missing-section">
                        <h3 class="missing-heading">Missing</h3>
                        <SetCarouselStrip
                          ariaLabel={`Missing sets for ${y}`}
                          carouselKind={`sets-missing-${group.id}-${yearKey}`}
                          prevLabel={`Scroll missing ${y} left`}
                          nextLabel={`Scroll missing ${y} right`}
                        >
                          {missingEntries.map((entry) => (
                            <div class="set-card set-card--missing media-era-card">
                              <img
                                src={`https://placehold.co/160x160?text=${encodeURIComponent(entry.setNumber)}`}
                                alt={`${entry.setNumber} - ${entry.name}`}
                                width="160"
                                height="160"
                                loading="lazy"
                              />
                              <div class="info">
                                <div class="name">{entry.setNumber} - {entry.name}</div>
                                <div class="meta">{y}</div>
                              </div>
                            </div>
                          ))}
                        </SetCarouselStrip>
                      </div>
                    )}
                  </div>
                );
              })
            )}
          </>
        ) : (
          <SetCarouselStrip
            ariaLabel={`${group.label} sets`}
            carouselKind={`sets-${group.id}-flat`}
            prevLabel="Scroll sets left"
            nextLabel="Scroll sets right"
          >
            {items.map((set) => (
              <a href={`/collection/${set.id}/?gen=${group.id}`} class="set-card media-era-card" data-set-id={set.id}>
                <img src={`/api/sets/photo/${set.id}`} alt={getSetDisplayLabel(set)} width="160" height="160" loading="lazy" />
                <div class="info">
                  <div class="name">{getSetDisplayLabel(set)}</div>
                  <div class="meta">{set.year}</div>
                </div>
                <span class="bulk-select-box" aria-hidden="true"></span>
              </a>
            ))}
          </SetCarouselStrip>
        )}
      </section>
    );
  })}
  </div>

  <script>
    (function () {
      const params = new URLSearchParams(window.location.search);
      const savedGroup = params.get('gen');
      const groupTabs = document.querySelectorAll('.generation-tab[data-group-id]');
      if (groupTabs.length) {
        const sections = document.querySelectorAll('.collection-section[data-group-id]');
        const groupIds = Array.from(groupTabs).map((t) => t.getAttribute('data-group-id')).filter(Boolean);

        function selectGroup(groupId, updateUrl = true) {
          groupTabs.forEach((tab) => {
            const active = tab.getAttribute('data-group-id') === groupId;
            tab.setAttribute('aria-selected', active ? 'true' : 'false');
          });
          sections.forEach((section) => {
            section.setAttribute('data-active', section.getAttribute('data-group-id') === groupId ? 'true' : 'false');
          });

          if (updateUrl && groupIds.includes(groupId)) {
            const url = new URL(window.location.href);
            url.searchParams.set('gen', groupId);
            const activeSection = document.querySelector('.collection-section[data-active="true"]');
            const carousel = activeSection?.querySelector('.year-carousel');
            const firstBtn = carousel?.querySelector('button[data-year]');
            const firstYear = firstBtn?.getAttribute('data-year');
            if (firstYear) {
              url.searchParams.set('year', firstYear);
              const cgId = carousel.getAttribute('data-group-id');
              if (cgId) {
                const btns = carousel.querySelectorAll('button[data-year]');
                const panes = document.querySelectorAll(`.year-pane[data-group-id="${cgId}"]`);
                btns.forEach((btn) => {
                  const isActive = btn.getAttribute('data-year') === firstYear;
                  btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
                  btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
                });
                panes.forEach((pane) => {
                  pane.setAttribute('data-active', pane.getAttribute('data-year') === firstYear ? 'true' : 'false');
                });

                // Media tab has an additional category layer. When switching groups,
                // reset the category selection in the newly active year pane.
                if (cgId === 'media') {
                  const activePane = Array.from(panes).find((pane) => pane.getAttribute('data-year') === firstYear);
                  const defaultBtn = activePane?.querySelector('.media-category-tab[data-category]');
                  const defaultCategory = defaultBtn?.getAttribute('data-category');
                  if (activePane && defaultCategory) {
                    const catButtons = activePane.querySelectorAll('.media-category-tab[data-category]');
                    catButtons.forEach((btn) => {
                      const active = btn.getAttribute('data-category') === defaultCategory;
                      btn.setAttribute('aria-selected', active ? 'true' : 'false');
                      btn.setAttribute('aria-pressed', active ? 'true' : 'false');
                    });
                    const catPanes = activePane.querySelectorAll('.media-category-pane[data-category]');
                    catPanes.forEach((pane) => {
                      pane.setAttribute('data-active', pane.getAttribute('data-category') === defaultCategory ? 'true' : 'false');
                    });
                  }
                }
              }
            } else {
              url.searchParams.delete('year');
            }
            window.history.replaceState({}, '', url.toString());
          }
        }

        let initialGroup = savedGroup && groupIds.includes(savedGroup) ? savedGroup : (groupTabs[0].getAttribute('data-group-id') || groupIds[0]);
        if (initialGroup) selectGroup(initialGroup, false);

        groupTabs.forEach((tab) => {
          tab.addEventListener('click', () => {
            const gid = tab.getAttribute('data-group-id');
            if (gid) selectGroup(gid);
          });
        });
      }

      const savedYear = params.get('year');
      const savedCategory = params.get('category');
      const focusId = params.get('focus');

      // Media tab: category selection inside each active year pane.
      document.querySelectorAll('.media-category-tab[data-category]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const yearPane = btn.closest('.year-pane[data-group-id="media"]');
          if (!yearPane) return;
          const category = btn.getAttribute('data-category');
          if (!category) return;

          const catButtons = yearPane.querySelectorAll('.media-category-tab[data-category]');
          catButtons.forEach((b) => {
            const active = b.getAttribute('data-category') === category;
            b.setAttribute('aria-selected', active ? 'true' : 'false');
            b.setAttribute('aria-pressed', active ? 'true' : 'false');
          });

          const catPanes = yearPane.querySelectorAll('.media-category-pane[data-category]');
          catPanes.forEach((pane) => {
            pane.setAttribute('data-active', pane.getAttribute('data-category') === category ? 'true' : 'false');
          });
        });
      });

      document.querySelectorAll('.year-carousel').forEach((carousel) => {
        const groupId = carousel.getAttribute('data-group-id');
        if (!groupId) return;
        const buttons = carousel.querySelectorAll('button[data-year]');
        const panes = document.querySelectorAll(`.year-pane[data-group-id="${groupId}"]`);
        const yearValues = Array.from(buttons).map((b) => b.getAttribute('data-year'));

        function selectYear(year, updateUrl = true) {
          buttons.forEach((btn) => {
            const active = btn.getAttribute('data-year') === year;
            btn.setAttribute('aria-selected', active ? 'true' : 'false');
            btn.setAttribute('aria-pressed', active ? 'true' : 'false');
          });
          panes.forEach((pane) => {
            pane.setAttribute('data-active', pane.getAttribute('data-year') === year ? 'true' : 'false');
          });

          // Media tab (for non-comics/books categories) has a second category layer.
          // On initial load, allow restoring `?category=...`. On user year changes, fall back to default.
          if (groupId === 'media') {
            const activePane = Array.from(panes).find((pane) => pane.getAttribute('data-year') === year);
            if (!activePane) return;

            const catButtons = activePane.querySelectorAll('.media-category-tab[data-category]');
            if (!catButtons || catButtons.length === 0) return;

            const defaultBtn = activePane.querySelector('.media-category-tab[data-category]');
            const defaultCategory = defaultBtn?.getAttribute('data-category');
            if (!defaultCategory) return;

            let targetCategory = defaultCategory;
            if (!updateUrl && savedCategory) {
              const hasSavedCategory = Array.from(catButtons).some((btn) => btn.getAttribute('data-category') === savedCategory);
              if (hasSavedCategory) targetCategory = savedCategory;
            }

            catButtons.forEach((btn) => {
              const active = btn.getAttribute('data-category') === targetCategory;
              btn.setAttribute('aria-selected', active ? 'true' : 'false');
              btn.setAttribute('aria-pressed', active ? 'true' : 'false');
            });

            const catPanes = activePane.querySelectorAll('.media-category-pane[data-category]');
            catPanes.forEach((pane) => {
              pane.setAttribute('data-active', pane.getAttribute('data-category') === targetCategory ? 'true' : 'false');
            });
          }
          if (updateUrl && yearValues.includes(year)) {
            const url = new URL(window.location.href);
            url.searchParams.set('year', year);
            window.history.replaceState({}, '', url.toString());
          }
        }

        if (savedYear && yearValues.includes(savedYear)) {
          selectYear(savedYear, false);
        }

        buttons.forEach((btn) => {
          btn.addEventListener('click', () => {
            const y = btn.getAttribute('data-year');
            if (y) selectYear(y);
          });
          if (btn.getAttribute('aria-selected') === 'true') btn.setAttribute('aria-pressed', 'true');
        });
      });

      // If returning from a media detail page, focus the requested thumbnail.
      if (focusId) {
        requestAnimationFrame(() => {
          const safeId = typeof CSS !== 'undefined' && typeof CSS.escape === 'function' ? CSS.escape(focusId) : focusId;
          const card = document.querySelector(`.media-card[data-media-id="${safeId}"]`);
          if (card && typeof card.scrollIntoView === 'function') {
            card.scrollIntoView({ behavior: 'auto', inline: 'start', block: 'nearest' });
          }
        });
      }

      // Media era carousels: left/right buttons (comics + books).
      document.querySelectorAll('.media-era-carousel-wrap').forEach((wrap) => {
        const mediaCarousel = wrap.querySelector('.media-era-carousel');
        if (!(mediaCarousel instanceof HTMLElement)) return;

        const prevBtn = wrap.querySelector('.media-era-prev');
        const nextBtn = wrap.querySelector('.media-era-next');
        const firstCard = mediaCarousel.querySelector('.media-era-card');
        const cardWidth = firstCard instanceof HTMLElement ? firstCard.getBoundingClientRect().width : 180;
        const scrollAmount = cardWidth + 16;

        if (prevBtn instanceof HTMLButtonElement) {
          prevBtn.addEventListener('click', () => {
            mediaCarousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
          });
        }
        if (nextBtn instanceof HTMLButtonElement) {
          nextBtn.addEventListener('click', () => {
            mediaCarousel.scrollBy({ left: scrollAmount, behavior: 'smooth' });
          });
        }
      });
    })();

    (function () {
      // Only select the card containers (not the checkbox inputs).
      const mediaCards = document.querySelectorAll('.media-card[data-media-href]');
      if (mediaCards.length === 0) return;

      const isEditHost = window.location.hostname === 'edit.bioniclecollective.com';
      if (isEditHost) {
        document.documentElement.setAttribute('data-host', 'edit');
      }

      function applyOwnedState(ownedIds) {
        const owned = new Set(ownedIds || []);
        mediaCards.forEach((card) => {
          const id = card.getAttribute('data-media-id');
          const isOwned = owned.has(id);
          if (isOwned) {
            card.classList.remove('set-card--missing');
          } else {
            card.classList.add('set-card--missing');
          }

          const cb = card.querySelector('.media-card-checkbox');
          if (cb instanceof HTMLInputElement) cb.checked = isOwned;

          // Keep aria-label consistent for accessibility.
          const label = card.getAttribute('aria-label');
          const base = label ? label.replace(/, (owned|not owned)\.?$/, '') : '';
          card.setAttribute('aria-label', base + (isOwned ? ', owned' : ', not owned'));
        });
      }

      // In edit mode: card click toggles ownership; view button navigates to detail.
      // In normal mode: card click navigates to detail.
      mediaCards.forEach((card) => {
        const href = card.getAttribute('data-media-href');
        if (!href) return;
        card.addEventListener('click', () => {
          if (isEditHost) {
            const cb = card.querySelector('.media-card-checkbox');
            if (cb instanceof HTMLInputElement) {
              cb.checked = !cb.checked;
              cb.dispatchEvent(new Event('change'));
            }
          } else {
            window.location.href = href;
          }
        });
        if (isEditHost) {
          const viewBtn = card.querySelector('.media-card-view-btn');
          if (viewBtn) {
            viewBtn.addEventListener('click', (e) => {
              e.stopPropagation();
              window.location.href = href;
            });
          }
        }
      });

      fetch('/api/media/collection')
        .then((r) => (r.ok ? r.json() : null))
        .then((data) => {
          if (data && Array.isArray(data.ownedIds)) applyOwnedState(data.ownedIds);
        })
        .catch(() => {});

      if (isEditHost) {
        // Immediate UI update on toggle; persistence happens via the Save button.
        mediaCards.forEach((card) => {
          const cb = card.querySelector('.media-card-checkbox');
          if (!(cb instanceof HTMLInputElement)) return;
          cb.addEventListener('change', () => {
            const isOwned = cb.checked;
            if (isOwned) {
              card.classList.remove('set-card--missing');
            } else {
              card.classList.add('set-card--missing');
            }
          });
        });

        document.querySelectorAll('.media-save-btn').forEach((btn) => {
          if (!(btn instanceof HTMLButtonElement)) return;
          btn.addEventListener('click', async () => {
            if (btn.disabled) return;
            btn.disabled = true;
            try {
              const checkboxes = document.querySelectorAll('.media-card-checkbox');
              const ownedIds = Array.from(checkboxes)
                .filter((cb) => cb instanceof HTMLInputElement && cb.checked)
                .map((cb) => cb.getAttribute('data-media-id'))
                .filter((id) => typeof id === 'string');

              const res = await fetch('/api/media/collection', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ownedIds }),
                credentials: 'include',
              });

              if (!res.ok) {
                if (res.status === 401) {
                  alert('Session expired. Please log in again.');
                } else {
                  const err = await res.text();
                  alert('Save failed (' + res.status + '). Check the console.');
                  console.error('Media save failed:', res.status, err);
                }
                return;
              }

              let data;
              try {
                data = await res.json();
              } catch {
                applyOwnedState(ownedIds);
                return;
              }

              if (data && Array.isArray(data.ownedIds)) {
                applyOwnedState(data.ownedIds);
              } else {
                applyOwnedState(ownedIds);
              }
              window.location.reload();
            } finally {
              btn.disabled = false;
            }
          });
        });
      }
    })();

    (function () {
      const maskCards = document.querySelectorAll('[data-mask-id]');
      if (maskCards.length === 0) return;

      const isEditHost = window.location.hostname === 'edit.bioniclecollective.com';
      if (isEditHost) {
        document.documentElement.setAttribute('data-host', 'edit');
      }

      function applyOwnedState(ownedIds) {
        const owned = new Set(ownedIds || []);
        maskCards.forEach((card) => {
          const id = card.getAttribute('data-mask-id');
          const isOwned = owned.has(id);
          if (isOwned) {
            card.classList.remove('set-card--missing');
          } else {
            card.classList.add('set-card--missing');
          }
          const cb = card.querySelector('.mask-card-checkbox');
          if (cb instanceof HTMLInputElement) cb.checked = isOwned;
          const label = card.getAttribute('aria-label');
          const base = label ? label.replace(/, (owned|not owned)\.?$/, '') : '';
          card.setAttribute('aria-label', base + (isOwned ? ', owned' : ', not owned'));
        });
      }

      fetch('/api/kanohi/collection')
        .then((r) => (r.ok ? r.json() : null))
        .then((data) => {
          if (data && Array.isArray(data.ownedIds)) applyOwnedState(data.ownedIds);
        })
        .catch(() => {});

      if (isEditHost) {
        maskCards.forEach((card) => {
          const cb = card.querySelector('.mask-card-checkbox');
          if (!(cb instanceof HTMLInputElement)) return;
          cb.addEventListener('change', () => {
            const isOwned = cb.checked;
            if (isOwned) {
              card.classList.remove('set-card--missing');
            } else {
              card.classList.add('set-card--missing');
            }
          });
        });

        const saveBtn = document.querySelector('.kanohi-save-btn');
        if (saveBtn instanceof HTMLButtonElement) {
          saveBtn.addEventListener('click', async () => {
            if (saveBtn.disabled) return;
            saveBtn.disabled = true;
            try {
              const checkboxes = document.querySelectorAll('.mask-card-checkbox');
              const ownedIds = Array.from(checkboxes)
                .filter((cb) => cb instanceof HTMLInputElement && cb.checked)
                .map((cb) => cb.getAttribute('data-mask-id'))
                .filter((id) => typeof id === 'string');
              const res = await fetch('/api/kanohi/collection', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ownedIds }),
                credentials: 'include',
              });
              if (!res.ok) {
                if (res.status === 401) {
                  alert('Session expired. Please log in again.');
                } else {
                  const err = await res.text();
                  alert('Save failed (' + res.status + '). Check the console.');
                  console.error('Kanohi save failed:', res.status, err);
                }
                return;
              }
              let data;
              try {
                data = await res.json();
              } catch {
                applyOwnedState(ownedIds);
                return;
              }
              if (data && Array.isArray(data.ownedIds)) {
                applyOwnedState(data.ownedIds);
              } else {
                applyOwnedState(ownedIds);
              }
              window.location.reload();
            } catch (e) {
              console.error('Kanohi save error:', e);
              alert('Save failed. Check the console.');
            } finally {
              saveBtn.disabled = false;
            }
          });
        }
      }
    })();

    (function () {
      const isEditHost = window.location.hostname === 'edit.bioniclecollective.com';
      if (!isEditHost) return;

      const toggleBtn = document.getElementById('bulk-edit-toggle');
      const bar = document.getElementById('bulk-edit-bar');
      const countEl = document.getElementById('bulk-edit-count');
      const applyBtn = document.getElementById('bulk-apply-btn') as HTMLButtonElement | null;
      const cancelBtn = document.getElementById('bulk-cancel-btn');
      const fieldDateCheck = document.getElementById('bulk-field-acquiredDate') as HTMLInputElement | null;
      const fieldFromCheck = document.getElementById('bulk-field-acquiredFrom') as HTMLInputElement | null;
      const fieldStatusCheck = document.getElementById('bulk-field-status') as HTMLInputElement | null;
      const inputMonth = document.getElementById('bulk-acquiredMonth') as HTMLSelectElement | null;
      const inputYear = document.getElementById('bulk-acquiredYear') as HTMLSelectElement | null;
      const inputFrom = document.getElementById('bulk-acquiredFrom') as HTMLInputElement | null;
      const inputStatus = document.getElementById('bulk-status') as HTMLSelectElement | null;

      if (!toggleBtn || !bar || !countEl || !applyBtn || !cancelBtn) return;

      const selectedIds = new Set<string>();
      let isBulkEdit = false;

      function hasEnabledFields() {
        return !!(fieldDateCheck?.checked || fieldFromCheck?.checked || fieldStatusCheck?.checked);
      }

      function updateBar() {
        const n = selectedIds.size;
        countEl!.textContent = n === 1 ? '1 set selected' : `${n} sets selected`;
        applyBtn!.textContent = `Apply to ${n} set${n !== 1 ? 's' : ''}`;
        applyBtn!.disabled = n === 0 || !hasEnabledFields();
      }

      function getPayload(): Record<string, string> {
        const fields: Record<string, string> = {};
        if (fieldDateCheck?.checked) {
          const month = inputMonth?.value ?? '';
          const year = inputYear?.value ?? '';
          fields.acquiredDate = year ? (month ? `${year}-${month}` : year) : '';
        }
        if (fieldFromCheck?.checked) fields.acquiredFrom = inputFrom?.value.trim() ?? '';
        if (fieldStatusCheck?.checked) fields.status = inputStatus?.value ?? '';
        return fields;
      }

      function enterBulkEdit() {
        isBulkEdit = true;
        document.documentElement.setAttribute('data-bulk-edit', 'true');
        selectedIds.clear();
        updateBar();
        toggleBtn!.textContent = 'Exit bulk edit';
      }

      function exitBulkEdit() {
        isBulkEdit = false;
        document.documentElement.removeAttribute('data-bulk-edit');
        selectedIds.clear();
        document.querySelectorAll('[data-set-id].bulk-selected').forEach((card) => {
          card.classList.remove('bulk-selected');
        });
        toggleBtn!.textContent = 'Bulk edit';
        // Reset field toggles
        if (fieldDateCheck) fieldDateCheck.checked = false;
        if (fieldFromCheck) fieldFromCheck.checked = false;
        if (fieldStatusCheck) fieldStatusCheck.checked = false;
        if (inputMonth) inputMonth.disabled = true;
        if (inputYear) inputYear.disabled = true;
        if (inputFrom) inputFrom.disabled = true;
        if (inputStatus) inputStatus.disabled = true;
      }

      // Card click — select/deselect in bulk edit mode (non-missing owned cards only)
      document.querySelectorAll('[data-set-id]').forEach((card) => {
        if (card.classList.contains('set-card--missing')) return;
        card.addEventListener('click', (e) => {
          if (!isBulkEdit) return;
          e.preventDefault();
          const id = card.getAttribute('data-set-id');
          if (!id) return;
          if (selectedIds.has(id)) {
            selectedIds.delete(id);
            card.classList.remove('bulk-selected');
          } else {
            selectedIds.add(id);
            card.classList.add('bulk-selected');
          }
          updateBar();
        });
      });

      // Field toggle enables/disables its inputs
      fieldDateCheck?.addEventListener('change', () => {
        const on = !!fieldDateCheck.checked;
        if (inputMonth) inputMonth.disabled = !on;
        if (inputYear) inputYear.disabled = !on;
        updateBar();
      });
      fieldFromCheck?.addEventListener('change', () => {
        if (inputFrom) inputFrom.disabled = !fieldFromCheck.checked;
        updateBar();
      });
      fieldStatusCheck?.addEventListener('change', () => {
        if (inputStatus) inputStatus.disabled = !fieldStatusCheck.checked;
        updateBar();
      });

      toggleBtn.addEventListener('click', () => {
        if (isBulkEdit) exitBulkEdit();
        else enterBulkEdit();
      });

      cancelBtn.addEventListener('click', exitBulkEdit);

      applyBtn.addEventListener('click', async () => {
        const payload = getPayload();
        if (Object.keys(payload).length === 0 || selectedIds.size === 0) return;
        applyBtn.disabled = true;
        applyBtn.textContent = 'Saving…';
        try {
          const res = await fetch('/api/collection/bulk', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ids: Array.from(selectedIds), ...payload }),
            credentials: 'include',
          });
          if (res.status === 401) {
            window.location.href = '/?next=' + encodeURIComponent(window.location.pathname);
            return;
          }
          if (!res.ok) {
            const err = await res.json().catch(() => ({}));
            alert('Save failed. ' + (err.error ?? res.status));
            applyBtn.disabled = false;
            updateBar();
            return;
          }
        } catch {
          alert('Network error. Please try again.');
          applyBtn.disabled = false;
          updateBar();
          return;
        }
        window.location.reload();
      });
    })();
  </script>

  <div class="bulk-edit-bar" id="bulk-edit-bar">
    <div class="bulk-edit-bar-inner">
      <span class="bulk-edit-count" id="bulk-edit-count">0 sets selected</span>

      <div class="bulk-edit-fields">
        <div class="bulk-field-row">
          <label class="bulk-field-label">
            <input type="checkbox" id="bulk-field-acquiredDate" />
            Date acquired
          </label>
          <div class="bulk-field-inputs">
            <select id="bulk-acquiredMonth" disabled>
              <option value="">—</option>
              {['January','February','March','April','May','June','July','August','September','October','November','December'].map((name, i) => (
                <option value={String(i + 1).padStart(2, '0')}>{name}</option>
              ))}
            </select>
            <select id="bulk-acquiredYear" disabled>
              <option value="">—</option>
              {Array.from({ length: 2026 - 2001 + 1 }, (_, i) => 2001 + i).reverse().map((y) => (
                <option value={y}>{y}</option>
              ))}
            </select>
          </div>
        </div>

        <div class="bulk-field-row">
          <label class="bulk-field-label">
            <input type="checkbox" id="bulk-field-acquiredFrom" />
            Purchased from
          </label>
          <div class="bulk-field-inputs">
            <input type="text" id="bulk-acquiredFrom" class="bulk-text-input" disabled placeholder="e.g. LEGO Store" />
          </div>
        </div>

        <div class="bulk-field-row">
          <label class="bulk-field-label">
            <input type="checkbox" id="bulk-field-status" />
            Status
          </label>
          <div class="bulk-field-inputs">
            <select id="bulk-status" disabled>
              <option value="">—</option>
              <option value="new">New</option>
              <option value="used-complete">Used – Complete</option>
              <option value="used-incomplete">Used – Incomplete</option>
            </select>
          </div>
        </div>
      </div>

      <div class="bulk-edit-actions">
        <button type="button" class="button-primary" id="bulk-apply-btn" disabled>Apply to 0 sets</button>
        <button type="button" class="button-secondary" id="bulk-cancel-btn">Cancel</button>
      </div>
    </div>
  </div>
</Layout>
