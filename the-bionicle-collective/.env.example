# Cloudflare auth (used by wrangler for maintenance scripts)
# Create at: dash.cloudflare.com → My Profile → API Tokens
# Requires: R2 Object Read & Write on the bionicle-collection bucket
CLOUDFLARE_API_TOKEN=

# Cloudflare account ID (shown in the right sidebar on any Cloudflare dashboard page)
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare R2 (for "In my Collection" overlay)
# Copy to .env and fill in your values. Variables used by src/utils/collectionStore.ts
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
# Optional: R2 object key (default: collection.json)
# R2_COLLECTION_STORE_KEY=collection.json

# Admin auth (required to edit "In my Collection")
ADMIN_SECRET=
