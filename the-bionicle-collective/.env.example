# Cloudflare R2 (for "In my Collection" overlay)
# Copy to .env and fill in your values. Variables used by src/utils/collectionStore.ts
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
# Optional: R2 object key (default: collection.json)
# R2_COLLECTION_STORE_KEY=collection.json

# Admin auth (required to edit "In my Collection")
ADMIN_SECRET=

