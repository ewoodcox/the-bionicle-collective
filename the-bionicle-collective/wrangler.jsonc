{
  "name": "the-bionicle-collective",
  "main": "./dist/_worker.js/index.js",
  "compatibility_date": "2025-02-23",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "REPLACE_WITH_SESSION_KV_ID"
    }
  ],
  "r2_buckets": [
    {
      "binding": "BIONICLE_COLLECTION",
      "bucket_name": "bionicle-collection",
      "remote": true
    }
  ]
}
