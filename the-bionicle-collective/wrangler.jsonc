{
  "name": "the-bionicle-collective",
  "compatibility_date": "2025-02-23",
  "compatibility_flags": ["nodejs_compat"],
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "REPLACE_WITH_SESSION_KV_ID"
    },
    {
      "binding": "COLLECTION_STORE",
      "id": "REPLACE_WITH_YOUR_KV_NAMESPACE_ID"
    }
  ]
}
